{
  "name": "@nyby/detox-component-testing",
  "version": "1.6.0",
  "description": "Component testing support for Detox and React Native",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "default": "./dist/test.js"
    },
    "./environment": {
      "default": "./dist/environment.js"
    }
  },
  "typesVersions": {
    "*": {
      "test": [
        "dist/test.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc && cp src/environment.js dist/environment.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "publish:public": "npm publish --access public",
    "format": "prettier --write \"src/**/*.{js,ts,tsx}\" \"example/**/*.{js,ts,tsx}\""
  },
  "peerDependencies": {
    "detox": "*",
    "react": "*",
    "react-native": "*",
    "react-native-launch-arguments": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.72.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
